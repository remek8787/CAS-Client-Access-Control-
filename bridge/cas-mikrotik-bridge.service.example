[Unit]
Description=CAS MikroTik Bridge API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ananta
Group=ananta
WorkingDirectory=/home/ananta/apps/cas-mikrotik-bridge
EnvironmentFile=/home/ananta/apps/cas-mikrotik-bridge/.env
ExecStart=/usr/bin/python3 /home/ananta/apps/cas-mikrotik-bridge/bridge_server.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false
ReadWritePaths=/home/ananta/apps/cas-mikrotik-bridge

[Install]
WantedBy=multi-user.target
